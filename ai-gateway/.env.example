# Port the gateway listens on.
PORT=8787

# MUST match the backend's AI_GATEWAY_SECRET (backend signs grants, gateway
# verifies them). In dev the backend defaults this to SECRET_KEY.
AI_GATEWAY_SECRET=change-me-to-match-backend

# Backend base URL for reporting token usage (Phase 4 metering). Point at the
# backend's /api prefix. Leave empty to disable usage reporting.
BACKEND_URL=http://localhost:8000/api

# Real vendor API keys — the ONLY place they live. A vendor with no key here is
# simply unavailable (the gateway returns 502 for it). Gemini is the default.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
