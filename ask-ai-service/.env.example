# Copy this to .env and fill in your values. .env is gitignored - never commit it.

# Provider API keys, injected into config.yaml (providers.*.api_key).
# A provider with no key still lists its models in /health, but /ask calls to
# it fail with 502 until the key is set.
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# Port the service listens on (used by run.py; hosted platforms override it
# via their own PORT). The frontend's ASK_AI_URL must point at this host:port.
PORT=8001

# OPTIONAL shared secret for hosted deployments. If set, POST /ask requires
# "Authorization: Bearer <token>" — set the SAME value as ASK_AI_SERVICE_TOKEN
# in the frontend host's (Vercel) env. Leave unset for local dev.
# ASK_AI_SERVICE_TOKEN=
