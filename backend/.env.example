# Copy this to .env and fill in your values. .env is gitignored — never commit it.

DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/docplatform

# JWT signing secret. MUST be set to a long random string (the code falls back to
# an INSECURE dev default otherwise) and MUST match the Hocuspocus server's
# JWT_SECRET so collaboration WebSocket auth accepts the same tokens.
SECRET_KEY=change-me-to-a-long-random-string

# Access token lifetime in minutes. Kept short now that the frontend auto-refreshes
# on 401 (a stolen/expired access token is only usable for this window).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token lifetime in days (server-stored, rotated on every /auth/refresh).
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Ask-AI (the editor's AI backend, app/services/ask_ai) -------------------
# Vendor API keys for the LLM router. These are the ONLY place AI keys live —
# they are read server-side and never reach the browser. Which models exist is
# declared in app/services/ask_ai/config.yaml; a key is required for each
# provider whose models you enable in the admin catalog.
GROQ_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
