# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
# node_modules must be ignored; package.json and package-lock.json should be pushed
# so other developers can run `npm install` to get the exact same dependency tree.
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build and development cache outputs
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# Testing coverage
/coverage

# Local environment variables and secret files
# Do NOT ignore .env.example if it is created, so users know what variables to set.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# IDEs, Editors and AI Assistants
.vscode/
.idea/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated files
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel deployment metadata
.vercel
